gssps:Aalenian
    a gssp:GSSP ;
    gts:stratotypeOf gts2020:BaseMiddleJurassic ;
    geo:hasGeometry
        [
            a geo:Geometry ;
            geo:asWKT "POINT (-1.8333 41.1708)"^^geo:wktLiteral ;
        ] ;
    gssp:boundaryLevel "base of Bed FZ 107" ;
    gssp:correlationEvents "Ammonite FAD Leioceras opalinum and Leioceras lineatum" ;
    schema:citation "Episodes 2001; 24: 166-175" ;
    schema:description "Fuentelsaz, Spain" ;
    schema:status "Ratified 2000" ;
.

gssps:Aeronian
    a gssp:GSSP ;
    gts:stratotypeOf gts2020:BaseAeronian ;
    geo:hasGeometry
        [
            a geo:Geometry ;
            geo:asWKT "POINT (-14.2119 49.923)"^^geo:wktLiteral ;
        ] ;
    gssp:boundaryLevel "within Želkovice Formation, 1.38 m above base" ;
    gssp:correlationEvents "Graptolite FAD Demirastrites Triangulates" ;
    schema:citation
        "https://stratigraphy.org/gssps/files/rhu-tely-pridoli.pdf"^^xsd:anyURI ,
        """Hlásná Třebaň GSSP: Štorch et al., Episodes forthcoming

Trefawr Track GSSP: Episodes 1985; 8: 101-103; Geol. Series, Nat. Mus. Wales 1989; 9: 36-50""" ;
    schema:description "Hlásná Třebaň, Bohemia, Czech Republic" ;
    schema:status """Ratified 2024;

to replace Trefawr Track, Wales, UK former GSSP""" ;
.

gssps:Albian
    a gssp:GSSP ;
    gts:stratotypeOf gts2020:BaseAlbian ;
    geo:hasGeometry
        [
            a geo:Geometry ;
            geo:asWKT "POINT (5.2973 44.5079)"^^geo:wktLiteral ;
        ] ;
    gssp:boundaryLevel "37.4 m above the base of the section and 0.4 m above the base of the laminated Niveau Kilian bed" ;
    gssp:correlationEvents "Lowest occurrence of the planktonic foraminifer Microhedbergella renilaevis" ;
    schema:citation
        "https://doi.org/10.18814/epiiugs/2017/v40i3/017021"^^xsd:anyURI ,
        "Episodes 40/3, p. 177-188, 2017" ;
    schema:description "Col de Pré-Guittard, Department of Drôme, southeastern France" ;
    schema:status "Ratified 2016" ;
.

gssps:Anisian
    a gssp:GSSP ;
    gts:stratotypeOf gts2020:BaseMiddleTriassic ;
    geo:hasGeometry
        [
            a geo:Geometry ;
            geo:asWKT "POINT (28.8022 45.0742)"^^geo:wktLiteral ;
        ] ;
    gssp:boundaryLevel "In Section B, the GSSP level will be either the FAD of conodont Chiosella timorensis at the base of Bed GR7 at ca. 7 m; OR the base of magnetozone MT1n at the 5.7 m level." ;
    gssp:correlationEvents "Conodont FAD Chiosella timorensis or Magnetic - base of magnetic polarity MT1n" ;
    schema:citation "Albertiana 36, 2007." ;
    schema:description "Candidate section at Desli Caira (Dobrogea, Romania); significant sections in Guizhou Province (China) and South Primorye (Russia)" ;
    schema:status "Proposed" ;
.

gssps:Aptian
    a gssp:GSSP ;
    gts:stratotypeOf gts2020:BaseAptian ;
    gssp:correlationEvents "Magnetic - base of Chron M0r; near FAD of Paradeshayesites oglanlensis ammonite zone" ;
    schema:description "candidate is Gorgo a Cerbara, Piobbico, Umbria-Marche, central Italy" ;
    schema:status "Proposed" ;
.

