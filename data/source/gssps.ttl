gssps:Aalenian
    a gssp:GSSP ;
    gts:stratotypeOf gts2020:BaseAalenian ;
    geo:hasGeometry
        [
            a geo:Geometry ;
            geo:asWKT "POINT (-1.8333 41.1708)"^^geo:wktLiteral ;
        ] ;
    gssp:boundaryLevel "base of Bed FZ 107" ;
    gssp:correlationEvents "Ammonite FAD Leioceras opalinum and Leioceras lineatum" ;
    schema:citation "Episodes 2001; 24: 166-175" ;
    schema:description "Fuentelsaz, Spain" ;
    schema:name "GSSP for the Aalenian" ;
.

gssps:Aeronian
