    schema:citation
        "https://stratigraphy.org/gssps/files/aquitanian.pdf"^^xsd:anyURI ,
        "Episodes 1997; 20: 23-28" ;
    schema:description "Lemme-Carrosio Section, Allessandria Province, Italy" ;
    schema:status "Ratified 1996" ;
.

