    schema:name "GSSP for the Albian" ;
.

gssps:Anisian
    a gssp:GSSP ;
    gts:stratotypeOf gts2020:BaseAnisian ;
    gssp:boundaryLevel "In Section B, the GSSP level will be either the FAD of conodont Chiosella timorensis at the base of Bed GR7 at ca. 7 m; OR the base of magnetozone MT1n at the 5.7 m level." ;
    gssp:correlationEvents "Conodont FAD Chiosella timorensis or Magnetic - base of magnetic polarity MT1n" ;
    schema:citation "Albertiana 36, 2007." ;
    schema:description "Candidate section at Desli Caira (Dobrogea, Romania); significant sections in Guizhou Province (China) and South Primorye (Russia)" ;
    schema:name "GSSP for the Anisian" ;
    schema:status "proposed" ;
.

